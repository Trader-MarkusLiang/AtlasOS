{
  "version": "parallel-track productization roadmap",
  "version_model": {
    "principle": "Atlas versions are parallel tracks, not one linear sequence.",
    "tracks": [
      "Atlas Core / Knowledge OS",
      "Atlas Runtime",
      "Atlas Cognitive Overlay",
      "Atlas UI / Product",
      "Atlas Data / Market Intelligence"
    ],
    "why_versions_differ": "Core v2.x, Runtime v0.x, UI v1.x/v2.x, and Data v0.x can coexist because they describe different product surfaces with different maturity levels."
  },
  "current_stage": "production validation + autonomous productization",
  "next_stage": "Decision Brief-first productization, market ingestion, portfolio context, forecast accountability",
  "active_version": "productization-sprint",
  "stability_status": "baseline_audited",
  "trust_status": "trust_calibrated_for_cognition_not_forecast_accuracy",
  "release_update_policy": "update this file during each Atlas runtime/UI release validation",
  "tracks": [
    {
      "track": "Atlas Core / Knowledge OS",
      "current_version": "v2.1 RC",
      "status": "released",
      "role": "Investment reasoning, Decision Engine, World Model, Portfolio/CDE governance.",
      "current_focus": "Production Trial discipline and Decision First usability."
    },
    {
      "track": "Atlas Runtime",
      "current_version": "v0.3.x / daemon trial",
      "status": "current",
      "role": "Local daemon, EventStream, DecisionLoop, telemetry, state store, safe runtime controls.",
      "current_focus": "Continuous operation, non-simulated ingestion, scheduler readiness, stability evidence."
    },
    {
      "track": "Atlas Cognitive Overlay",
      "current_version": "CIL -> UMIS + feedback overlays",
      "status": "experimental",
      "role": "Symbolic causal/world/latent/physics/law/unified cognition with trust-gated feedback.",
      "current_focus": "Use existing overlays safely; do not add v0.8 Causal Interaction until a verified gap requires it."
    },
    {
      "track": "Atlas UI / Product",
      "current_version": "UI v2.0 + provider v1.4.4",
      "status": "current",
      "role": "Browser control surface, settings, provider health/model picker, roadmap/workflow pages.",
      "current_focus": "Decision Brief-first Home, setup wizard, predictions page, ordinary-user language."
    },
    {
      "track": "Atlas Data / Market Intelligence",
      "current_version": "market-data utilities v0.2",
      "status": "partial",
      "role": "Ticker registry, akshare/yfinance snapshot utilities, anomaly checks.",
      "current_focus": "Normalize market observations into Input Router -> EventStream and expose freshness."
    }
  ],
